const PRIVATE_KEY = process.env.PRIVATE_KEY;
const SAFE_WALLET = process.env.SAFE_WALLET;
const WS_RPC_URLS = process.env.WS_RPC_URLS?.split(',').map(s => s.trim());
const TELEGRAM_BOT_TOKEN = process.env.TELEGRAM_BOT_TOKEN;
const TELEGRAM_CHAT_ID = process.env.TELEGRAM_CHAT_ID;

if (!PRIVATE_KEY || !SAFE_WALLET || !WS_RPC_URLS || WS_RPC_URLS.length === 0) {
  console.error('Missing env variables: PRIVATE_KEY, SAFE_WALLET, WS_RPC_URLS');
  process.exit(1);
}

const TOKENS_PATH = path.resolve('./tokens.json');
if (!fs.existsSync(TOKENS_PATH)) {
  console.error('Missing tokens.json file');
  process.exit(1);
}
const tokens = JSON.parse(fs.readFileSync(TOKENS_PATH, 'utf8'));

//
// === UTILS ===
//

const LOG_FILE = path.resolve('./bot.log');
function log(...args) {
  const msg = `[${new Date().toISOString()}] ${args.join(' ')}`;
  console.log(msg);
  fs.appendFileSync(LOG_FILE, msg + '\n');
}

function delay(ms) {
  return new Promise(res => setTimeout(res, ms));
}

async function telegramNotify(message) {
  if (!TELEGRAM_BOT_TOKEN || !TELEGRAM_CHAT_ID) return;
  try {
    await fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ chat_id: TELEGRAM_CHAT_ID, text: message })
    });
  } catch (e) {
    log('Telegram notify failed:', e.message);
  }
}

//
// === BLOCK REORGANIZATION HANDLING ===
//

let lastBlockHash = '';
let lastBlockNumber = 0;

async function handleBlockReorganization(blockNumber) {
  try {
    const block = await multiProvider.currentProvider.getBlock(blockNumber);
    if (!block) return;
    
    // ตรวจสอบ reorg
    if (lastBlockHash && block.parentHash !== lastBlockHash && blockNumber > lastBlockNumber) {
      log(`🔄 Chain reorganization detected at block ${blockNumber}`);
      log(`   Expected parent: ${lastBlockHash}`);
      log(`   Actual parent: ${block.parentHash}`);
      
      await telegramNotify(`🔄 Chain reorg detected! Rechecking balances...`);
      
      // รอสักครู่ให้ chain เสถียร
      await delay(5000);
      
      // ตรวจสอบ balance ใหม่ทั้งหมด
      await recheckAllBalances();
    }
    
    lastBlockHash = block.hash;
    lastBlockNumber = blockNumber;
  } catch (e) {
    log(`Block reorg handling error: ${e.message}`);
  }
}

async function recheckAllBalances() {
  log('🔍 Rechecking all token balances after reorg...');
  
  for (const t of tokens) {
    try {
      const tokenInfo = tokenContracts.get(t.address.toLowerCase());
      if (!tokenInfo) continue;
      
      const balance = await tokenInfo.contract.balanceOf(wallet.address);
      if (balance.gt(0)) {
        log(`💰 Reorg recheck found ${tokenInfo.symbol}: ${ethers.utils.formatUnits(balance, tokenInfo.decimals)}`);
        await instantTransfer(t.address, balance);
      }
    } catch (err) {
      log(`Reorg recheck error for ${t.symbol}: ${err.message}`);
    }
  }
}

//
// === SANDWICH ATTACK PROTECTION ===
//

async function detectSandwichAttack(tokenAddress, ourGasPrice) {
  try {
    // ตรวจสอบ mempool หา sandwich bots
    const mempool = await multiProvider.currentProvider.send('txpool_content', []);
    
    if (!mempool || !mempool.pending) return { isSandwich: false, count: 0 };
    
    let suspiciousCount = 0;
    
    // วิเคราะห์ pending transactions
    for (const address in mempool.pending) {
      const txs = mempool.pending[address];
      for (const nonce in txs) {
        const tx = txs[nonce];
        
        // ตรวจหา tx ที่เป็น sandwich candidate
        if (tx.to && tx.to.toLowerCase() === tokenAddress.toLowerCase()) {
          const txGasPrice = ethers.BigNumber.from(tx.gasPrice || tx.maxFeePerGas || 0);
          
          // ถ้ามี tx ที่ gas สูงกว่าเรา = อาจเป็น sandwich
          if (txGasPrice.gte(ourGasPrice)) {
            suspiciousCount++;
          }
        }
      }
    }
    
    const isSandwich = suspiciousCount > 3; // threshold
    
    if (isSandwich) {
      log(`🥪 Sandwich attack detected! ${suspiciousCount} competing transactions`);
    }
    
    return { isSandwich, count: suspiciousCount };
  } catch (e) {
    log(`Sandwich detection error: ${e.message}`);
    return { isSandwich: false, count: 0 };
  }
}

//
// === ADVANCED MEV PROTECTION ===
//

async function analyzeMEVCompetition(tokenAddress, ourGasPrice) {
  try {
    const mempool = await multiProvider.currentProvider.send('txpool_content', []);
    
    if (!mempool || !mempool.pending) return { competitors: 0, maxGasPrice: ourGasPrice };
    
    let competitors = 0;
    let maxGasPrice = ourGasPrice;
    
    // วิเคราะห์คู่แข่งใน mempool
    for (const address in mempool.pending) {
      const txs = mempool.pending[address];
      for (const nonce in txs) {
        const tx = txs[nonce];
        
        if (tx.to && tx.to.toLowerCase() === tokenAddress.toLowerCase()) {
          const txGasPrice = ethers.BigNumber.from(tx.gasPrice || tx.maxFeePerGas || 0);
          
          if (txGasPrice.gte(ourGasPrice)) {
            competitors++;
            if (txGasPrice.gt(maxGasPrice)) {
              maxGasPrice = txGasPrice;
            }
          }
        }
      }
    }
    
    return { competitors, maxGasPrice };
  } catch (e) {
    log(`MEV competition analysis error: ${e.message}`);
    return { competitors: 0, maxGasPrice: ourGasPrice };
  }
}

function calculateCompetitiveGasPrice(baseGasPrice, competitors, maxCompetitorGas) {
  if (competitors === 0) return baseGasPrice;
  
  // ปรับ gas price ตามจำนวนคู่แข่ง
  let multiplier = 100; // base 100%
  
  if (competitors > 10) multiplier = 200; // +100% ถ้าแข่งขันสูง
  else if (competitors > 5) multiplier = 150; // +50% ถ้าแข่งขันปานกลาง
  else if (competitors > 2) multiplier = 120; // +20% ถ้าแข่งขันน้อย
  
  const adjustedGasPrice = baseGasPrice.mul(multiplier).div(100);
  
  // ถ้าคู่แข่งมี gas สูงกว่า ให้เพิ่มอีก 10%
  if (maxCompetitorGas.gt(adjustedGasPrice)) {
    return maxCompetitorGas.mul(110).div(100);
  }
  
  return adjustedGasPrice;
}

//
// === FLASHLOAN DETECTION ===
//

function isFlashloanAttack(txReceipt) {
  // ตรวจจับ flashloan จากจำนวน events และ gas usage
  const eventCount = txReceipt.logs.length;
  const gasUsed = txReceipt.gasUsed;
  
  return eventCount > 20 || gasUsed.gt(ethers.BigNumber.from(1000000));
}

async function analyzeIncomingTransaction(txHash) {
  try {
    const tx = await multiProvider.currentProvider.getTransaction(txHash);
    if (!tx) return { isFlashloan: false };
    
    // ตรวจสอบ gas limit สูงผิดปกติ
    const highGasLimit = tx.gasLimit.gt(ethers.BigNumber.from(500000));
    
    // ตรวจสอบ contract interaction ซับซ้อน
    const complexInteraction = tx.data && tx.data.length > 1000;
    
    return {
      isFlashloan: highGasLimit && complexInteraction,
      gasLimit: tx.gasLimit,
      dataSize: tx.data ? tx.data.length : 0
    };
  } catch (e) {
    return { isFlashloan: false };
  }
}

//
// === PRIORITY FEE OPTIMIZATION ===
//

let networkCongestion = 0;

async function getOptimalPriorityFee(provider) {
  try {
    const pendingBlock = await provider.getBlock('pending');
    networkCongestion = pendingBlock.transactions.length;
    
    // ปรับ priority fee ตาม congestion
    if (networkCongestion > 300) {
      log(`🔥 High congestion: ${networkCongestion} pending txs`);
      return ethers.utils.parseUnits('15', 'gwei'); // สูงมาก
    }
    if (networkCongestion > 200) {
      log(`⚠️ Medium congestion: ${networkCongestion} pending txs`);
      return ethers.utils.parseUnits('8', 'gwei'); // ปานกลาง
    }
    if (networkCongestion > 100) {
      log(`📊 Low congestion: ${networkCongestion} pending txs`);
      return ethers.utils.parseUnits('4', 'gwei'); // ต่ำ
    }
    
    return ethers.utils.parseUnits('2', 'gwei'); // ปกติ
  } catch (e) {
    log('Failed to get network congestion:', e.message);
    return ethers.utils.parseUnits('3', 'gwei'); // fallback
  }
}

//
// === 2. DYNAMIC GAS STRATEGY + GAS ESTIMATION ===
//

async function getCompetitiveGasPrice(provider, tokenAddress = null) {
  try {
    const [gasPrice, feeData, optimalPriorityFee] = await Promise.all([
      provider.getGasPrice(),
      provider.getFeeData(),
      getOptimalPriorityFee(provider)
    ]);
    
    let finalGasPrice = gasPrice;
    let finalPriorityFee = optimalPriorityFee;
    
    // === ADVANCED MEV PROTECTION ===
    if (tokenAddress) {
      const mevAnalysis = await analyzeMEVCompetition(tokenAddress, gasPrice);
      if (mevAnalysis.competitors > 0) {
        log(`🛡️ MEV competition detected: ${mevAnalysis.competitors} competitors`);
        finalGasPrice = calculateCompetitiveGasPrice(gasPrice, mevAnalysis.competitors, mevAnalysis.maxGasPrice);
        
        // ปรับ priority fee ตามการแข่งขัน
        if (mevAnalysis.competitors > 5) {
          finalPriorityFee = finalPriorityFee.mul(150).div(100); // +50%
        }
      }
    }
    
    // ใช้ EIP-1559 ถ้าเป็นไปได้
    if (feeData.maxFeePerGas) {
      const baseFee = feeData.lastBaseFeePerGas || ethers.utils.parseUnits('20', 'gwei');
      
      return {
        maxFeePerGas: baseFee.add(finalPriorityFee).mul(150).div(100), // base + priority + 50%
        maxPriorityFeePerGas: finalPriorityFee,
        type: 2
      };
    }
    
    // Legacy gas pricing with congestion adjustment
    const adjustedGasPrice = networkCongestion > 200 
      ? finalGasPrice.mul(200).div(100) // +100% ถ้า congestion สูง
      : finalGasPrice.mul(150).div(100); // +50% ปกติ
    
    return { 
      gasPrice: adjustedGasPrice,
      type: 0
    };
  } catch (e) {
    log('Gas price fetch failed:', e.message);
    return { gasPrice: ethers.utils.parseUnits('25', 'gwei'), type: 0 };
  }
}

// === GAS ESTIMATION WITH FALLBACK ===
async function estimateGasWithFallback(contract, method, args) {
  try {
    const estimated = await contract.estimateGas[method](...args);
    return estimated.mul(120).div(100); // +20% buffer
  } catch (e) {
    log(`Gas estimation failed: ${e.message}, using fallback`);
    return ethers.BigNumber.from(200000); // fallback
  }
}

// === MEV PROTECTION ===
function getMEVProtectionDelay() {
  // ปรับ delay ตาม network congestion
  const baseDelay = Math.floor(Math.random() * 500) + 100; // 100-600ms
  const congestionMultiplier = networkCongestion > 200 ? 0.5 : 1; // ลด delay ถ้า congestion สูง
  
  return Math.floor(baseDelay * congestionMultiplier);
}

//
// === 3. OPTIMIZED MULTI-RPC PROVIDER (CONNECTION POOLING) ===
//

class OptimizedMultiRpcProvider extends EventEmitter {
  constructor(urls) {
    super();
    this.urls = urls;
    // สร้าง connection pool หลายตัวต่อ RPC
    this.connectionPool = urls.map(url => {
      return Array(3).fill().map(() => new ethers.providers.WebSocketProvider(url));
    }).flat();
    this.latencies = new Array(this.connectionPool.length).fill(Infinity);
    this.currentIndex = 0;
    this.healthCheckIntervalMs = 30_000;
    this.healthCheckTimer = null;
    this.init();
  }

  async init() {
    await this.measureLatencies();
    this.selectBestProvider();
    this.setupListeners();
    this.startHealthCheck();
    this.setupBlockListener();
  }

  setupBlockListener() {
    // === BLOCK REORGANIZATION HANDLING ===
    this.currentProvider.on('block', handleBlockReorganization);
  }

  async measureLatency(index) {
    const p = this.connectionPool[index];
    const start = Date.now();
    try {
      await p.getBlockNumber();
      this.latencies[index] = Date.now() - start;
    } catch {
      this.latencies[index] = Infinity;
    }
  }

  async measureLatencies() {
    await Promise.all(this.connectionPool.map((_, i) => this.measureLatency(i)));
  }

  selectBestProvider() {
    const minLatency = Math.min(...this.latencies);
    this.currentIndex = this.latencies.indexOf(minLatency);
    log(`Selected RPC #${this.currentIndex} latency ${this.latencies[this.currentIndex]}ms`);
    this.emit('providerChanged', this.currentProvider);
  }

  get currentProvider() {
    return this.connectionPool[this.currentIndex];
  }

  // ใช้ provider แบบสุ่มเพื่อกระจาย load
  getRandomProvider() {
    const healthyProviders = this.connectionPool.filter((_, i) => this.latencies[i] < Infinity);
    return healthyProviders[Math.floor(Math.random() * healthyProviders.length)] || this.currentProvider;
  }

  setupListeners() {
    this.connectionPool.forEach((p, i) => {
      p._websocket.on('close', async (code) => {
        log(`RPC #${i} websocket closed with code ${code}`);
        await this.measureLatencies();
        this.selectBestProvider();
      });
      p._websocket.on('error', async (err) => {
        log(`RPC #${i} websocket error: ${err.message}`);
        await this.measureLatencies();
        this.selectBestProvider();
      });
    });
  }

  startHealthCheck() {
    this.healthCheckTimer = setInterval(async () => {
      await this.measureLatencies();
      this.selectBestProvider();
    }, this.healthCheckIntervalMs);
  }

  stopHealthCheck() {
    clearInterval(this.healthCheckTimer);
  }
}

//
// === TOKEN CONTRACT SETUP ===
//

const ERC20_ABI = [
  "function balanceOf(address) view returns (uint256)",
  "function transfer(address to, uint256 amount) returns (bool)",
  "function decimals() view returns (uint8)",
  "event Transfer(address indexed from, address indexed to, uint256 value)"
];

let wallet;
let multiProvider;
const tokenContracts = new Map();
const tokenProcessing = new Map();

// === 4. PRE-SIGNED TRANSACTIONS ===
const preSignedTxs = new Map();

// === TRANSACTION REPLACEMENT ===
const pendingTxs = new Map(); // track pending transactions
const TX_REPLACEMENT_TIMEOUT = 30000; // 30 seconds

async function prepareCounterTransfer(tokenAddress, expectedAmount) {
  const tokenInfo = tokenContracts.get(tokenAddress.toLowerCase());
  if (!tokenInfo) return;
  
  try {
    const gasConfig = await getCompetitiveGasPrice(multiProvider.currentProvider, tokenAddress);
    const nonce = await wallet.getTransactionCount('pending');
    
    // เตรียม transaction ไว้ล่วงหน้า
    const unsignedTx = await tokenInfo.contract.populateTransaction.transfer(SAFE_WALLET, expectedAmount);
    unsignedTx.gasLimit = await estimateGasWithFallback(tokenInfo.contract, 'transfer', [SAFE_WALLET, expectedAmount]);
    unsignedTx.nonce = nonce;
    Object.assign(unsignedTx, gasConfig);
    
    const signedTx = await wallet.signTransaction(unsignedTx);
    preSignedTxs.set(tokenAddress.toLowerCase(), { 
      signedTx, 
      nonce,
      gasPrice: gasConfig.gasPrice || gasConfig.maxFeePerGas
    });
    
    log(`📝 Pre-signed tx prepared for ${tokenInfo.symbol} (congestion: ${networkCongestion})`);
  } catch (e) {
    log(`Failed to prepare pre-signed tx for ${tokenAddress}: ${e.message}`);
  }
}

// === 1. MEMPOOL MONITORING WITH FLASHLOAN DETECTION ===
async function setupMempoolMonitoring() {
  multiProvider.currentProvider.on('pending', async (txHash) => {
    try {
      const tx = await multiProvider.currentProvider.getTransaction(txHash);
      if (tx && tx.to && tokenContracts.has(tx.to.toLowerCase())) {
        // ตรวจจับ transaction ที่กำลังจะส่งโทเค็นมาให้เรา
        const tokenInfo = tokenContracts.get(tx.to.toLowerCase());
        const iface = new ethers.utils.Interface(ERC20_ABI);
        
        try {
          const decoded = iface.parseTransaction(tx);
          if (decoded.name === 'transfer' && decoded.args.to.toLowerCase() === wallet.address.toLowerCase()) {
            
            // === FLASHLOAN DETECTION ===
            const analysis = await analyzeIncomingTransaction(txHash);
            if (analysis.isFlashloan) {
              log(`🚨 FLASHLOAN DETECTED! Skipping ${tokenInfo.symbol} transfer`);
              log(`   Gas limit: ${analysis.gasLimit}, Data size: ${analysis.dataSize}`);
              await telegramNotify(`🚨 Flashloan attack detected on ${tokenInfo.symbol}! Transaction skipped.`);
              return; // ไม่ทำอะไร ถ้าเป็น flashloan
            }
            
            log(`🚨 Mempool detected incoming ${tokenInfo.symbol} transfer (Safe)`);
            // เตรียม transaction ล่วงหน้า
            await prepareCounterTransfer(tx.to, decoded.args.amount);
          }
        } catch (parseError) {
          // ignore parsing errors
        }
      }
    } catch (e) {
      // ignore errors
    }
  });
}

async function instantTransfer(tokenAddress, amount) {
  // === SANDWICH ATTACK PROTECTION ===
  const gasConfig = await getCompetitiveGasPrice(multiProvider.currentProvider, tokenAddress);
  const ourGasPrice = gasConfig.gasPrice || gasConfig.maxFeePerGas;
  
  const sandwichCheck = await detectSandwichAttack(tokenAddress, ourGasPrice);
  if (sandwichCheck.isSandwich) {
    log(`🥪 Sandwich attack detected! Delaying transfer for ${tokenAddress}`);
    await telegramNotify(`🥪 Sandwich attack detected! Waiting for better opportunity...`);
    
    // รอให้ sandwich bots ผ่านไปก่อน
    await delay(3000 + Math.random() * 2000); // 3-5 วินาที
  }
  
  // === MEV PROTECTION ===
  const mevDelay = getMEVProtectionDelay();
  log(`🛡️ MEV protection delay: ${mevDelay}ms (congestion: ${networkCongestion})`);
  await delay(mevDelay);
  
  const preSignedData = preSignedTxs.get(tokenAddress.toLowerCase());
  if (preSignedData) {
    // ส่ง pre-signed transaction ทันที
    try {
      const txResponse = await multiProvider.getRandomProvider().sendTransaction(preSignedData.signedTx);
      log(`⚡ Instant transfer: ${txResponse.hash}`);
      
      // Track pending transaction for replacement
      pendingTxs.set(txResponse.hash, {
        tokenAddress,
        amount,
        gasPrice: preSignedData.gasPrice,
        nonce: preSignedData.nonce,
        timestamp: Date.now()
      });
      
      preSignedTxs.delete(tokenAddress.toLowerCase());
      return txResponse;
    } catch (e) {
      log(`Pre-signed tx failed: ${e.message}`);
      preSignedTxs.delete(tokenAddress.toLowerCase());
    }
  }
  
  // fallback ไปใช้วิธีปกติ
  enqueueTransfer(tokenAddress, amount);
}

// === TRANSACTION REPLACEMENT ===
async function replaceStuckTransaction(txHash, txData) {
  try {
    const tokenInfo = tokenContracts.get(txData.tokenAddress.toLowerCase());
    if (!tokenInfo) return;
    
    log(`🔄 Replacing stuck transaction: ${txHash}`);
    
    // เพิ่ม gas price ตาม network congestion
    const multiplier = networkCongestion > 200 ? 120 : 110; // +20% ถ้า congestion สูง, +10% ปกติ
    const newGasPrice = txData.gasPrice.mul(multiplier).div(100);
    
    const unsignedTx = await tokenInfo.contract.populateTransaction.transfer(SAFE_WALLET, txData.amount);
    const gasLimit = await estimateGasWithFallback(tokenInfo.contract, 'transfer', [SAFE_WALLET, txData.amount]);
    
    unsignedTx.gasLimit = gasLimit;
    unsignedTx.nonce = txData.nonce; // ใช้ nonce เดียวกัน
    
    if (newGasPrice.gt(ethers.utils.parseUnits('150', 'gwei'))) {
      // ถ้า gas สูงเกินไป ใช้ EIP-1559
      const gasConfig = await getCompetitiveGasPrice(multiProvider.currentProvider, txData.tokenAddress);
      Object.assign(unsignedTx, gasConfig);
    } else {
      unsignedTx.gasPrice = newGasPrice;
    }
    
    const signedTx = await wallet.signTransaction(unsignedTx);
    const newTxResponse = await multiProvider.getRandomProvider().sendTransaction(signedTx);
    
    log(`✅ Replacement tx sent: ${newTxResponse.hash} (congestion: ${networkCongestion})`);
    
    // Update tracking
    pendingTxs.delete(txHash);
    pendingTxs.set(newTxResponse.hash, {
      ...txData,
      gasPrice: newGasPrice,
      timestamp: Date.now()
    });
    
    return newTxResponse;
  } catch (e) {
    log(`❌ Failed to replace transaction: ${e.message}`);
  }
}

// Monitor and replace stuck transactions
setInterval(async () => {
  const now = Date.now();
  for (const [txHash, txData] of pendingTxs.entries()) {
    if (now - txData.timestamp > TX_REPLACEMENT_TIMEOUT) {
      try {
        const receipt = await multiProvider.currentProvider.getTransactionReceipt(txHash);
        if (!receipt) {
          // Transaction still pending, replace it
          await replaceStuckTransaction(txHash, txData);
        } else {
          // === FLASHLOAN DETECTION ON CONFIRMED TX ===
          if (isFlashloanAttack(receipt)) {
            log(`🚨 Flashloan detected in confirmed tx: ${txHash}`);
            await telegramNotify(`🚨 Flashloan confirmed in tx: ${txHash}`);
          }
          
          // Transaction confirmed, remove from tracking
          pendingTxs.delete(txHash);
        }
      } catch (e) {
        // Transaction might be stuck, try to replace
        await replaceStuckTransaction(txHash, txData);
      }
    }
  }
}, 15000); // Check every 15 seconds

// === 5. FAST EVENT HANDLING ===
async function setupFastEventListening() {
  for (const [address, tokenInfo] of tokenContracts) {
    // Listen บน provider หลายตัวพร้อมกัน
    multiProvider.connectionPool.forEach((provider, index) => {
      const contract = new ethers.Contract(address, ERC20_ABI, provider);
      contract.on('Transfer', async (from, to, value) => {
        if (to.toLowerCase() === wallet.address.toLowerCase()) {
          log(`📥 Fast event #${index}: ${tokenInfo.symbol} amount: ${ethers.utils.formatUnits(value, tokenInfo.decimals)}`);
          await instantTransfer(address, value);
        }
      });
    });
  }
}

async function setupContracts() {
  tokenContracts.clear();
  tokenProcessing.clear();

  for (const t of tokens) {
    const contract = new ethers.Contract(t.address, ERC20_ABI, wallet);
    tokenContracts.set(t.address.toLowerCase(), { contract, decimals: t.decimals, symbol: t.symbol });
    tokenProcessing.set(t.address.toLowerCase(), false);
  }
  
  // Setup fast event listening
  await setupFastEventListening();
}

//
// === PRIORITY QUEUE + NONCE MANAGEMENT ===
//

class TxQueue {
  constructor() {
    this.queue = [];
    this.processing = false;
    this.nonce = null;
  }

  async initNonce() {
    this.nonce = await wallet.getTransactionCount('pending');
  }

  enqueue(job) {
    this.queue.push(job);
    if (!this.processing) {
      this.process();
    }
  }

  async process() {
    this.processing = true;
    while (this.queue.length > 0) {
      const job = this.queue.shift();
      await transferWithRetry(job.tokenAddress, job.amount);
    }
    this.processing = false;
  }
}

const txQueue = new TxQueue();

function enqueueTransfer(tokenAddress, amount) {
  txQueue.enqueue({ tokenAddress: tokenAddress.toLowerCase(), amount });
}

//
// === TRANSFER WITH RETRY (ปรับปรุงแล้ว) ===
//

async function transferWithRetry(tokenAddress, amount) {
  if (tokenProcessing.get(tokenAddress)) return;
  tokenProcessing.set(tokenAddress, true);

  const tokenInfo = tokenContracts.get(tokenAddress);
  if (!tokenInfo) {
    log(`Token contract not found for ${tokenAddress}`);
    tokenProcessing.set(tokenAddress, false);
    return;
  }
  const { contract, decimals, symbol } = tokenInfo;

  if (!txQueue.nonce) {
    await txQueue.initNonce();
  }

  let nonce = txQueue.nonce;
  const maxRetries = 5;
  let attempt = 0;

  while (attempt < maxRetries) {
    attempt++;

    try {
      // ตรวจสอบ balance ก่อนส่ง
      const balance = await contract.balanceOf(wallet.address);
      const sendAmount = amount.gt(balance) ? balance : amount;
      if (sendAmount.isZero()) {
        log(`❌ ${symbol} balance is zero, skipping transfer`);
        tokenProcessing.set(tokenAddress, false);
        return false;
      }

      // === SANDWICH ATTACK PROTECTION ===
      const gasConfig = await getCompetitiveGasPrice(multiProvider.currentProvider, tokenAddress);
      const ourGasPrice = gasConfig.gasPrice || gasConfig.maxFeePerGas;
      
      const sandwichCheck = await detectSandwichAttack(tokenAddress, ourGasPrice);
      if (sandwichCheck.isSandwich) {
        log(`🥪 Sandwich detected during retry for ${symbol}, waiting...`);
        await delay(2000); // รอ 2 วินาที
      }

      // สร้าง transaction with dynamic gas estimation
      const unsignedTx = await contract.populateTransaction.transfer(SAFE_WALLET, sendAmount);
      unsignedTx.gasLimit = await estimateGasWithFallback(contract, 'transfer', [SAFE_WALLET, sendAmount]);
      unsignedTx.nonce = nonce;
      Object.assign(unsignedTx, gasConfig);

      const signedTx = await wallet.signTransaction(unsignedTx);
      const txResponse = await multiProvider.getRandomProvider().sendTransaction(signedTx);

      log(`✅ Sent ${symbol} tx: ${txResponse.hash} attempt ${attempt} nonce ${nonce} (congestion: ${networkCongestion})`);
      
      // Track for potential replacement
      pendingTxs.set(txResponse.hash, {
        tokenAddress,
        amount: sendAmount,
        gasPrice: gasConfig.gasPrice || gasConfig.maxFeePerGas,
        nonce,
        timestamp: Date.now()
      });

      await txResponse.wait(1);
      
      // Remove from tracking after confirmation
      pendingTxs.delete(txResponse.hash);

      log(`✅ Confirmed ${symbol} transfer tx: ${txResponse.hash}`);

      nonce++;
      txQueue.nonce = nonce;

      tokenProcessing.set(tokenAddress, false);

      await telegramNotify(`✅ Transfer success: ${symbol} ${ethers.utils.formatUnits(sendAmount, decimals)} TX: ${txResponse.hash}`);

      return true;
    } catch (err) {
      log(`⚠️ Transfer attempt ${attempt} failed for ${symbol}: ${err.message}`);

      if (err.message.includes('nonce too low')) {
        nonce = await wallet.getTransactionCount('pending');
        txQueue.nonce = nonce;
      } else if (err.message.includes('insufficient funds')) {
        log(`❌ Insufficient ETH for gas!`);
        await telegramNotify(`❌ Insufficient ETH for gas!`);
        tokenProcessing.set(tokenAddress, false);
        return false;
      }

      nonce++;
      txQueue.nonce = nonce;

      await delay(2 ** attempt * 1000);
    }
  }

  log(`❌ Failed to transfer ${symbol} after ${maxRetries} attempts`);
  tokenProcessing.set(tokenAddress, false);
  await telegramNotify(`❌ Failed to transfer ${symbol} after ${maxRetries} attempts`);
  return false;
}

//
// === 7. AGGRESSIVE POLLING ===
//

async function aggressivePolling() {
  const promises = tokens.map(async (t) => {
    try {
      const tokenInfo = tokenContracts.get(t.address.toLowerCase());
      if (!tokenInfo) return;

      const balance = await tokenInfo.contract.balanceOf(wallet.address);
      if (balance.gt(0)) {
        log(`⌚ Aggressive poll detected ${tokenInfo.symbol} balance: ${ethers.utils.formatUnits(balance, tokenInfo.decimals)}`);
        await instantTransfer(t.address, balance);
      }
    } catch (err) {
      log(`Aggressive polling error for ${t.symbol}: ${err.message}`);
    }
  });
  
  await Promise.all(promises);
}

async function startAggressivePolling() {
  while (true) {
    await aggressivePolling();
    await delay(100); // 100ms แทน 1000ms
  }
}

